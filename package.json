{
  "name": "@xbgmsharp/postgsail-mcp-server",
  "mcpName": "io.github.xbgmsharp/postgsail",
  "version": "0.0.7",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "pack": "npx @anthropic-ai/mcpb pack",
    "tests": "bash tests/tests.sh",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbgmsharp/postgsail-mcp-server.git"
  },
  "keywords": [
    "signalk",
    "postgsail",
    "mcp",
    "model context protocol"
  ],
  "author": "Francois Lacroix <xbgmsharp@gmail.com>",
  "license": "Apache-2.0",
  "description": "A Model Context Protocol (MCP) server that provides AI agents with read-only access to PostgSail marine data systems.",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^22.19.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
